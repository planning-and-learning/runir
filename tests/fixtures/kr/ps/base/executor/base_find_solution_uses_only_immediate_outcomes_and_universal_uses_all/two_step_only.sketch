(:sketch
        (:features
            (:boolean
                (:symbol C)
                (:expression (b_nonempty (c_some (r_atomic_state "carry") (c_top))))
            )
            (:boolean
                (:symbol R)
                (:expression
                    (b_nonempty
                        (c_some
                            (r_atomic_goal "at" true)
                            (c_atomic_state "at-robby")
                        )
                    )
                )
            )
        )
        (:rules
            (:rule
                (:symbol two-step-only)
                (:expression
                    (:conditions (negative C) (negative R))
                    (:effects (positive C) (positive R))
                )
            )
        )
    )

