@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

include("${CMAKE_CURRENT_LIST_DIR}/cmake/configure_yggdrasil.cmake")
include("${CMAKE_CURRENT_LIST_DIR}/cmake/configure_tyr.cmake")
configure_yggdrasil()
configure_tyr()

find_dependency(fmt CONFIG REQUIRED PATHS ${CMAKE_PREFIX_PATH} NO_DEFAULT_PATH)
if(fmt_FOUND)
    message(STATUS "Found fmt: ${fmt_DIR} (found version ${fmt_VERSION})")
endif()

find_dependency(tyr CONFIG REQUIRED COMPONENTS core PATHS ${CMAKE_PREFIX_PATH} NO_DEFAULT_PATH)
if(tyr_FOUND)
    message(STATUS "Found tyr: ${tyr_DIR} (found version ${tyr_VERSION})")
endif()

set(_template_feature_supported_components core)
if(NOT template_feature_FIND_COMPONENTS)
    set(template_feature_FIND_COMPONENTS core)
endif()

foreach(_comp ${template_feature_FIND_COMPONENTS})
    if(NOT _comp IN_LIST _template_feature_supported_components)
        set(template_feature_FOUND FALSE)
        set(template_feature_NOT_FOUND_MESSAGE "Unsupported component: ${_comp}")
        return()
    endif()
    include("${CMAKE_CURRENT_LIST_DIR}/template_feature${_comp}Targets.cmake")
endforeach()

get_filename_component(template_feature_CONFIG_DIR "${CMAKE_CURRENT_LIST_FILE}" PATH)
message(STATUS "Found template_feature: ${template_feature_CONFIG_DIR} (found version ${template_feature_VERSION})")
