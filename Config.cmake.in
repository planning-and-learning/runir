@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

include("${CMAKE_CURRENT_LIST_DIR}/cmake/find_python_native_packages.cmake")
runir_find_python_native_prefix(pyyggdrasil YGGDRASIL_NATIVE_PREFIX)
runir_find_python_native_prefix(pytyr TYR_NATIVE_PREFIX)

find_dependency(yggdrasil 0.0.14 CONFIG REQUIRED PATHS ${CMAKE_PREFIX_PATH} NO_DEFAULT_PATH)
if(yggdrasil_FOUND)
    message(STATUS "Found yggdrasil: ${yggdrasil_DIR} (found version ${yggdrasil_VERSION})")
endif()

find_dependency(fmt CONFIG REQUIRED PATHS ${CMAKE_PREFIX_PATH} NO_DEFAULT_PATH)
if(fmt_FOUND)
    message(STATUS "Found fmt: ${fmt_DIR} (found version ${fmt_VERSION})")
endif()

find_dependency(tyr 0.0.22 CONFIG REQUIRED COMPONENTS core PATHS ${CMAKE_PREFIX_PATH} NO_DEFAULT_PATH)
if(tyr_FOUND)
    message(STATUS "Found tyr: ${tyr_DIR} (found version ${tyr_VERSION})")
endif()

set(_runir_supported_components core datasets graphs kr)
if(NOT runir_FIND_COMPONENTS)
    set(runir_FIND_COMPONENTS core)
endif()

set(_runir_components_to_load)
foreach(_comp ${runir_FIND_COMPONENTS})
    if(NOT _comp IN_LIST _runir_supported_components)
        set(runir_FOUND FALSE)
        set(runir_NOT_FOUND_MESSAGE "Unsupported component: ${_comp}")
        return()
    endif()
    list(APPEND _runir_components_to_load ${_comp})
endforeach()

if(NOT TARGET runir::core)
    include("${CMAKE_CURRENT_LIST_DIR}/runirTargets.cmake")
endif()

get_filename_component(runir_CONFIG_DIR "${CMAKE_CURRENT_LIST_FILE}" PATH)
message(STATUS "Found runir: ${runir_CONFIG_DIR} (found version ${runir_VERSION})")
