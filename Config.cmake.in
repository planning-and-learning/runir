@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Dependencies

include("${CMAKE_CURRENT_LIST_DIR}/cmake/bootstrap_pyyggdrasil.cmake")

find_dependency(yggdrasil @RUNIR_YGGDRASIL_REQUIRED_VERSION@ CONFIG PATHS ${CMAKE_PREFIX_PATH} NO_DEFAULT_PATH)

yggdrasil_find_python_native_prefix(pytyr TYR_NATIVE_PREFIX)

find_dependency(tyr @RUNIR_TYR_REQUIRED_VERSION@ CONFIG COMPONENTS core PATHS ${CMAKE_PREFIX_PATH} NO_DEFAULT_PATH)

# Components

set(_runir_supported_components core datasets graphs kr)
if(NOT runir_FIND_COMPONENTS)
    set(runir_FIND_COMPONENTS core)
endif()

foreach(_component IN LISTS runir_FIND_COMPONENTS)
    if(_component IN_LIST _runir_supported_components)
        set(runir_${_component}_FOUND TRUE)
    else()
        set(runir_${_component}_FOUND FALSE)
        if(runir_FIND_REQUIRED_${_component})
            set(runir_FOUND FALSE)
            set(runir_NOT_FOUND_MESSAGE "Unsupported component: ${_component}")
            unset(_component)
            unset(_runir_supported_components)
            return()
        endif()
    endif()
endforeach()

# Targets

include("${CMAKE_CURRENT_LIST_DIR}/runirTargets.cmake")

unset(_component)
unset(_runir_supported_components)
